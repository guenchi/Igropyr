{
  "name": "igropyr",
  "version": "1.1.15",
  "description": "High-concurrency HTTP server framework for Chez Scheme on libuv: Erlang-style green processes, a Let-It-Crash worker pool, process-per-dialogue conversations, and s-expression RPC.",
  "keywords": [
    "scheme",
    "chez-scheme",
    "r6rs",
    "http",
    "server",
    "web-framework",
    "libuv",
    "actor-model",
    "erlang",
    "websocket"
  ],
  "homepage": "https://igropyr.com",
  "bugs": {
    "url": "https://github.com/guenchi/Igropyr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guenchi/Igropyr.git"
  },
  "license": "MIT",
  "author": "guenchi",
  "scripts": {
    "start": "CHEZSCHEMELIBDIRS=.. CHEZSCHEMELIBEXTS=.chezscheme.sls::.chezscheme.so:.ss::.so:.sls::.so:.scm::.so:.sch::.so:.sc::.so scheme --script test/run-otp.sc",
    "test": "bash test/run-all.sh"
  },
  "files": [
    "*.sc",
    "*.ss",
    "test/",
    "README.zh-CN.md"
  ]
}
